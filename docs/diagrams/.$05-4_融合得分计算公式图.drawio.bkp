        <mxCell id="p3f" value="CatFactor(c) =&#xa;Σ(w_child × 0.5^depth)" style="rounded=0;whiteSpace=wrap;html=1;fontSize=9;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;align=center;fontFamily=Courier New;" parent="1" vertex="1">
          <mxGeometry x="585" y="330" width="195" height="38" as="geometry" />
        </mxCell>

        <mxCell id="p4" value="④ 调节系数 C" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="580" y="382" width="200" height="20" as="geometry" />
        </mxCell>
        <mxCell id="p4f" value="CatFactor &gt; 0:&#xa;C = (1+2·CF)/3&#xa;&#xa;CatFactor = 0:&#xa;C = 0.10 (双路/仅KG)&#xa;C = 0.05 (仅CF)" style="rounded=0;whiteSpace=wrap;html=1;fontSize=9;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;align=left;spacingLeft=12;fontFamily=Courier New;" parent="1" vertex="1">
