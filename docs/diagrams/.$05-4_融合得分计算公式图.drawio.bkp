        <mxCell id="panel" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=2;" parent="1" vertex="1">
          <mxGeometry x="560" y="80" width="240" height="500" as="geometry" />
        </mxCell>

        <mxCell id="panel_t" value="公式汇总" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="600" y="90" width="160" height="28" as="geometry" />
        </mxCell>

        <mxCell id="panel_hr" value="" style="line;html=1;strokeColor=#000000;strokeWidth=1;" parent="1" vertex="1">
          <mxGeometry x="575" y="120" width="210" height="2" as="geometry" />
        </mxCell>

        <mxCell id="p1" value="① 归一化" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="580" y="130" width="200" height="20" as="geometry" />
        </mxCell>
        <mxCell id="p1f" value="cfNorm = CF / max(CF)&#xa;kgNorm = KG / max(KG)" style="rounded=0;whiteSpace=wrap;html=1;fontSize=9;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;align=center;fontFamily=Courier New;" parent="1" vertex="1">
          <mxGeometry x="585" y="158" width="195" height="38" as="geometry" />
        </mxCell>

        <mxCell id="p2" value="② 基础加权" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="580" y="210" width="200" height="20" as="geometry" />
        </mxCell>
        <mxCell id="p2f" value="baseScore =&#xa;α·cfNorm + (1−α)·kgNorm&#xa;α = 0.6" style="rounded=0;whiteSpace=wrap;html=1;fontSize=9;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;align=center;fontFamily=Courier New;" parent="1" vertex="1">
          <mxGeometry x="585" y="238" width="195" height="50" as="geometry" />
        </mxCell>

        <mxCell id="p3" value="③ CatFactor" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;fontStyle=1;" parent="1" vertex="1">
