        <mxCell id="final_formula" value="finalScore(i) = baseScore(i) × C" style="rounded=0;whiteSpace=wrap;html=1;fontSize=13;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=2;align=center;fontFamily=Courier New;fontStyle=1;" parent="1" vertex="1">
