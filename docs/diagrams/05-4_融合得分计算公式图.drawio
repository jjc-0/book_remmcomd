<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/24.7.5 Chrome/126.0.6478.183 Electron/31.3.0 Safari/537.36" version="24.7.5">
  <diagram name="融合得分计算" id="score">
    <mxGraphModel dx="1436" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="混合融合得分计算公式" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=20;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="132" y="49" width="500" height="36" as="geometry" />
        </mxCell>
        <mxCell id="phase1" value="阶段一：Min-Max 归一化" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="325" y="85" width="220" height="24" as="geometry" />
        </mxCell>
        <mxCell id="f1" value="cfNorm(i) = CF(i) ÷ max(CF)&#xa;kgNorm(i) = KG(i) ÷ max(KG)&#xa;     均映射至 [0, 1]" style="rounded=0;whiteSpace=wrap;html=1;fontSize=12;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=2;align=left;spacingLeft=20;fontFamily=Courier New;" parent="1" vertex="1">
          <mxGeometry x="280" y="112" width="225" height="72" as="geometry" />
        </mxCell>
        <mxCell id="arr_phase1_2" style="endArrow=classic;html=1;strokeColor=#000000;strokeWidth=1.5;" parent="1" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="389.5" y="184" as="sourcePoint" />
            <mxPoint x="389.5" y="222" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="phase2" value="阶段二：基础加权得分" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="271" y="189" width="200" height="24" as="geometry" />
        </mxCell>
        <mxCell id="f2a" value="baseScore(i) = α·cfNorm(i) + (1−α)·kgNorm(i)" style="rounded=0;whiteSpace=wrap;html=1;fontSize=12;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=2;align=center;fontFamily=Courier New;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="216" y="223" width="344" height="41" as="geometry" />
        </mxCell>
        <mxCell id="f2b" value="其中 α = 0.6，协同过滤权重 60%，知识图谱权重 40%" style="rounded=0;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=1;align=center;dashed=1;" parent="1" vertex="1">
          <mxGeometry x="239.5" y="294" width="297" height="36" as="geometry" />
        </mxCell>
        <mxCell id="ZcsOTX0H8tsQCNqcZQ11-1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" parent="1" source="f2a" target="f2b" edge="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arr_phase2_3" style="endArrow=classic;html=1;strokeColor=#000000;strokeWidth=1.5;" parent="1" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="387.5" y="326" as="sourcePoint" />
            <mxPoint x="387.5" y="367" as="targetPoint" />
